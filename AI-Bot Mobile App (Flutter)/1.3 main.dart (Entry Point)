import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:ai_bot_app/config/theme.dart';
import 'package:ai_bot_app/config/router.dart';
import 'package:ai_bot_app/services/ws_service.dart';
import 'package:ai_bot_app/services/discovery_service.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
  // Initialize services
  await DiscoveryService.initialize();
  
  runApp(
    const ProviderScope(
      child: AIBotApp(),
    ),
  );
}

class AIBotApp extends ConsumerStatefulWidget {
  const AIBotApp({super.key});

  @override
  ConsumerState<AIBotApp> createState() => _AIBotAppState();
}

class _AIBotAppState extends ConsumerState<AIBotApp> {
  @override
  void initState() {
    super.initState();
    
    // Listen to connectivity changes
    ref.read(wsServiceProvider).initConnectivityListener();
  }

  @override
  Widget build(BuildContext context) {
    final router = ref.watch(routerProvider);
    final themeMode = ref.watch(themeProvider);
    
    return MaterialApp.router(
      title: 'AI-Bot',
      debugShowCheckedModeBanner: false,
      theme: AppTheme.lightTheme,
      darkTheme: AppTheme.darkTheme,
      themeMode: themeMode,
      routerConfig: router,
    );
  }
}
